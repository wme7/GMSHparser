// ============================================================
// Uniform Triangular mesh on [0,1]x[0,1]
// ============================================================

// -----------------------------------------------------------
// Mesh resolution parameter
// -----------------------------------------------------------
lc = 0.1;   // characteristic element size

// -----------------------------------------------------------
// Points
// -----------------------------------------------------------
Point(1) = {0.0, 0.0, 0, lc};   // bottom-left
Point(2) = {1.0, 0.0, 0, lc};   // bottom-right
Point(3) = {1.0, 1.0, 0, lc};   // top-right
Point(4) = {0.0, 1.0, 0, lc};   // top-left

// -----------------------------------------------------------
// Lines
// -----------------------------------------------------------
Line(1) = {1, 2};   // bottom
Line(2) = {2, 3};   // right
Line(3) = {3, 4};   // top
Line(4) = {4, 1};   // left

// -----------------------------------------------------------
// Curve Loop and Surface
// -----------------------------------------------------------
Curve Loop(1) = {1, 2, 3, 4};
Plane Surface(1) = {1};

// -----------------------------------------------------------
// Physical groups (for boundary conditions / export)
// -----------------------------------------------------------
Physical Curve("bottom", 1) = {1};
Physical Curve("right",  2) = {2};
Physical Curve("top",    3) = {3};
Physical Curve("left",   4) = {4};

Physical Surface("domain", 10) = {1};

// -----------------------------------------------------------
// Global mesh options
// -----------------------------------------------------------
Mesh.Algorithm = 6;   // Frontal-Delaunay (high-quality triangles)
